# Accela MCP — required environment variables
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Required: Accela Developer Portal app credentials ---
# Register an app at https://developer.accela.com (My Apps → Add New App).
# Targeted Users: Agency. Authorized Redirect URIs must include the value below.
ACCELA_APP_ID=your_app_id_here
ACCELA_APP_SECRET=your_app_secret_here

# --- Required: redirect URI for the OAuth flow ---
# Must exactly match the value registered on the Developer Portal.
# The interactive `accela-mcp auth` flow binds a one-shot listener on the host:port.
ACCELA_REDIRECT_URI=http://localhost:8765/oauth/callback

# --- Required: local encryption key for token storage ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Treat this like a password. If lost, you must re-run `accela-mcp auth`.
ACCELA_MCP_KEY=replace_with_fernet_key

# --- Optional ---
# Path to capabilities.yaml. Defaults to platformdirs user config dir.
# ACCELA_MCP_CONFIG_PATH=/path/to/capabilities.yaml

# Path to encrypted token file. Defaults to platformdirs user config dir.
# ACCELA_MCP_TOKEN_PATH=/path/to/tokens.json

# Override log level. Default INFO.
# ACCELA_MCP_LOG_LEVEL=DEBUG

# Override log format. json (default in production) | console (human-readable, dev only).
# ACCELA_MCP_LOG_FORMAT=console
